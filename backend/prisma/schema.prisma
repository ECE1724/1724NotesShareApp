generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  displayName  String
  passwordHash String
  isAdmin      Boolean @default(false)

  ownedFiles   FileItem[]   @relation("FileOwner")
  fileAccesses FileAccess[]
  annotations  Annotation[]
}

model Department {
  id   Int    @id @default(autoincrement())
  code String @unique
  name String

  courses Course[]

  @@map("department")
}

model Course {
  id           Int    @id @default(autoincrement())
  departmentId Int
  courseCode   String @unique
  title        String

  department Department @relation(fields: [departmentId], references: [id])
  files      FileItem[]
}

model FileItem {
  id        Int      @id @default(autoincrement())
  courseId  Int
  ownerId   Int
  title     String
  fileUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course      Course       @relation(fields: [courseId], references: [id])
  owner       User         @relation("FileOwner", fields: [ownerId], references: [id])
  fileAccess  FileAccess[]
  annotations Annotation[]
}

model FileAccess {
  fileId      Int
  userId      Int
  accessLevel AccessLevel

  file FileItem @relation(fields: [fileId], references: [id])
  user User     @relation(fields: [userId], references: [id])

  @@id([fileId, userId])
}

model Annotation {
  id         Int      @id @default(autoincrement())
  fileId     Int
  authorId   Int
  parentId   Int?
  anchorJson Json
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  file    FileItem     @relation(fields: [fileId], references: [id])
  author  User         @relation(fields: [authorId], references: [id])
  parent  Annotation?  @relation("AnnotationReplies", fields: [parentId], references: [id])
  replies Annotation[] @relation("AnnotationReplies")
}

enum AccessLevel {
  OWNER
  COLLABORATOR
  VIEWER
}
